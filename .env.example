# Environment Variables Template
# Copy this file to .env and fill in actual values

# Data Analysis Configuration
EDA_INPUT_DATA_PATH=data/raw/orders.csv
EDA_OUTPUT_PATH=data/outputs/
EDA_REFERENCE_DATE=2026-06-02

# Python Environment
PYTHONPATH=.
LOG_LEVEL=INFO

# Data Quality Thresholds
NULL_THRESHOLD=0.05
OUTLIER_IQR_MULTIPLIER=1.5
MIN_RECORDS=100

# Analysis Parameters
RFM_CLUSTERS=3
OUTLIER_METHOD=iqr

# Optional: Database Connection (if connecting to live DB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=decodelabs
DB_USER=analyst
DB_PASSWORD=

# Optional: API Configuration (for future backend)
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30
